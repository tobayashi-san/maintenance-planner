# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-256-bit-random-secret-here

# Optional image override for docker deployments
# WARTUNGSKALENDER_IMAGE=ghcr.io/tobayashi-san/maintenance-planner:latest

# Server port
PORT=3000

# Internal deployment example
APP_URL=http://10.0.9.120:3000
ALLOWED_ORIGIN=http://10.0.9.120:3000

# Optional public HTTPS hostname for reverse proxy / Outlook Web
# PUBLIC_HOSTNAME=calendar.example.com
# ACME_EMAIL=ops@example.com
# Optional internal HTTPS hostname for LAN use with Docker-only internal TLS
# INTERNAL_TLS_HOSTNAME=wartungskalender.intern

# If you use the optional reverse proxy setup, use these instead:
# APP_URL=https://calendar.example.com
# ALLOWED_ORIGIN=https://calendar.example.com
# For internal TLS, docker-compose.internal-tls.yml sets APP_URL/ALLOWED_ORIGIN automatically.

# Required when starting an empty production instance
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=use-a-long-random-password
